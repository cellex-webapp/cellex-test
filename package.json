{
  "name": "cellex-test",
  "version": "1.0.0",
  "description": "Automated testing for Cellex web application using Mocha, Selenium and Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "mocha tests/**/*.test.js --require config/setup.js --timeout 60000 --exit",
    "test:auth": "mocha tests/auth/*.test.js --require config/setup.js --timeout 60000 --exit",
    "test:buying": "mocha tests/buying/*.test.js --require config/setup.js --timeout 60000 --exit",
    "test:vendor": "mocha tests/vendor/*.test.js --require config/setup.js --timeout 60000 --exit",
    "test:headless": "SET HEADLESS=true&& mocha tests/**/*.test.js --require config/setup.js --timeout 60000 --exit",
    "test:chrome": "SET BROWSER=chrome&& mocha tests/**/*.test.js --require config/setup.js --timeout 60000 --exit",
    "test:firefox": "SET BROWSER=firefox&& mocha tests/**/*.test.js --require config/setup.js --timeout 60000 --exit"
  },
  "keywords": [
    "selenium",
    "mocha",
    "automation",
    "testing",
    "page-object-model"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "chai": "^4.3.10",
    "chromedriver": "^142.0.3",
    "faker": "^5.5.3",
    "geckodriver": "^4.3.0",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "selenium-webdriver": "^4.38.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  }
}
